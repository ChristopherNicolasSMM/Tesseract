# .env_modelo — Tesseract
#
# Copie para `.env` e ajuste os valores. Segue a regra de ouro da
# skill 03: aqui só vão segredos e configurações que exigem restart
# (chave de API, string de conexão, SECRET_KEY). Parâmetro alterável
# em runtime vai em `system_config` (tabela), nunca aqui.
#
# Nenhuma variável abaixo é obrigatória para rodar em desenvolvimento
# (todas têm default seguro no código) — exceto DATABASE_URL quando
# TESSERACT_ENV=production.

# ──────────────────────────────────────────────────────────────────
# Core — ambiente e segurança
# ──────────────────────────────────────────────────────────────────

# development | production | testing (default: development)
TESSERACT_ENV=development

# Chave de assinatura de sessão Flask — TROCAR em produção.
# Default em código: "dev-secret-change-me" (NUNCA usar em produção).
SECRET_KEY=dev-secret-change-me

# String de conexão do banco. Em desenvolvimento, se omitida, usa
# SQLite local (sqlite:///tesseract_dev.db) — zero setup.
# Em produção é OBRIGATÓRIA (Postgres) — o app recusa subir sem ela
# (core/config.py: "nenhum fallback silencioso é permitido").
# DATABASE_URL=postgresql://usuario:senha@host:5432/tesseract

# ──────────────────────────────────────────────────────────────────
# Sistema de Tasks (Core) — agendamento automático (APScheduler)
# ──────────────────────────────────────────────────────────────────
#
# Opt-in explícito. Sem isso, o Monitor de Tarefas (/admin/tasks)
# continua funcionando para execução manual ("Executar agora"), só
# não roda nada sozinho em background. Nunca liga em TESTING.

TASK_SCHEDULER_ENABLED=false

# ──────────────────────────────────────────────────────────────────
# addon_device_manager — cliente MQTT
# ──────────────────────────────────────────────────────────────────
#
# Opt-in explícito. Sem MQTT_ENABLED=true, device_service continua
# funcionando (cache local via get_value/set_value), só não há
# comunicação de fato com hardware via broker. Nunca liga em TESTING.

MQTT_ENABLED=false
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=tesseract_device_manager

# Opcionais — sem autenticação no broker por padrão (decisão registrada
# em docs/skills/05-proposta-addon-device-manager-e-mqtt.md, §2.7).
# MQTT_USERNAME=
# MQTT_PASSWORD=

# Prefixo aplicado a todo tópico MQTT (ver core/event_bus vs MQTT em
# docs/skills/05-proposta-addon-device-manager-e-mqtt.md, seção 6).
# Precisa ser o MESMO valor configurado no lado do
# tesseract-device-bridge (repositório separado), senão os dois lados
# não se encontram nos tópicos.
MQTT_TOPIC_PREFIX=tesseract
