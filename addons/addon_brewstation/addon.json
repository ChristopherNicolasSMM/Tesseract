{
  "name": "brewstation",
  "label": "BrewStation",
  "version": "1.0.0",
  "description": "Plataforma de gestão para cervejarias artesanais",
  "author": "S2M Tech",
  "type": "addon",
  "table_prefix": "brewstation",
  "tesseract_min_version": "1.0.0",
