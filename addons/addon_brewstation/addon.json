      "table_prefix_suffix": "yeastbank",
      "enabled_by_default": true,
      "requires": []
    },
    {
      "name": "feature_mash_control",
      "label": "Mash Control",
      "table_prefix_suffix": "mashctrl",
      "enabled_by_default": true,
